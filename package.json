{
  "name": "sushila",
  "version": "1.0.0",
  "description": "A full-stack e-commerce website for a sushi store. Built with the PERN stack (PostgreSQL, Express.js, React, Node.js).",
  "main": "index.js",
  "scripts": {
    "dev-backend": "cd backend && npm run dev",
    "build-backend": "npm run build-shared && cd backend && npm run build",
    "start-backend": "cd backend && node ./dist/index.js",
    "prod-start-backend": "npm run build-backend && npm run start-backend",
    "build-shared": "cd shared && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adibdev58/SushiLA.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/adibdev58/SushiLA/issues"
  },
  "homepage": "https://github.com/adibdev58/SushiLA#readme",
  "workspaces": [
    "shared",
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "lowercase-keys": "^4.0.1"
  }
}
